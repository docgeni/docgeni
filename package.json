{
  "name": "docgeni",
  "version": "2.8.0-next.4",
  "scripts": {
    "ng": "ng",
    "docgeni": "cross-env DOCGENI_ENV=development NODE_ENV=development ts-node --project ./packages/cli/tsconfig.json ./packages/cli/bin/docgeni",
    "start": "pnpm run start:docs",
    "start:docs": "pnpm docgeni serve",
    "build:a-lib": "ng build a-lib --configuration production",
    "build": "pnpm run build:deps && pnpm run build:cli && pnpm run build:template && pnpm run build:dist",
    "build:template": "ng build template && pnpm run build-styles",
    "build:preset": "ng build preset",
    "build:toolkit": "pnpm --filter @docgeni/toolkit run build",
    "build:ngdoc": "pnpm --filter @docgeni/ngdoc run build",
    "build:core": "pnpm --filter @docgeni/core run build && cpx \"./packages/core/src/**/*.json\" ./packages/core/lib",
    "build:deps": "pnpm run build:toolkit && pnpm run build:ngdoc && pnpm run build:core",
    "build:cli": "pnpm --filter @docgeni/cli run build",
    "sync-ng-cli-schema": "ts-node --project ./scripts/tsconfig.json ./scripts/transform-angular-builder-schema.ts",
    "// test:mocha": "cross-env TS_NODE_PROJECT='./packages/cli/tsconfig.json' DOCGENI_ENV=test mocha --timeout 999999 packages/**/test/**/*.spec.ts --require ts-node/register/transpile-only",
    "test-template": "ng test template",
    "test": "cross-env TS_NODE_PROJECT='./packages/cli/tsconfig.json' DOCGENI_ENV=test node --require ts-node/register/transpile-only ./test/bootstrap.ts",
    "test-coverage": "rimraf ./coverage && rimraf ./nyc_output && nyc pnpm test",
    "report-coverage": "cat ./coverage/lcov.info | coveralls",
    "lint": "pnpm run lint:lib",
    "lint:lib": "eslint",
    "lint:ng": "ng lint",
    "e2e": "ng e2e",
    "build-docs": "cross-env DOCGENI_ENV=development ts-node --project ./packages/cli/tsconfig.json ./packages/cli/bin/docgeni build",
    "build-docs:dev": "pnpm run build:deps && cross-env DOCGENI_ENV=development ts-node --project ./packages/cli/tsconfig.json ./packages/cli/bin/docgeni build --configuration development",
    "build-gh-pages": "cross-env DOCGENI_ENV=development ts-node --project ./packages/cli/tsconfig.json ./packages/cli/bin/docgeni build --configuration production --base-href=/docgeni/",
    "tsc": "tsc -p ./packages/docgeni",
    "sync-interfaces": "ts-node --project ./scripts/tsconfig.json ./scripts/sync-interfaces.ts",
    "sync-template-version": "ts-node --project ./scripts/tsconfig.json ./scripts/sync-template-version.ts",
    "build:dist": "ts-node --project ./scripts/tsconfig.json ./scripts/build-dist.ts",
    "release": "pnpm run build && pnpm run release-only",
    "release-only": "wpm release",
    "pub": "wpm publish && pnpm run pub-only",
    "pub-only": "pnpm run pub-lib",
    "pub-next": "wpm publish && pnpm run pub-only-next",
    "pub-only-next": "pnpm run pub-lib-next",
    "pub-docs": "pnpm run build-docs && cpx ./package.json ./dist/docgeni-site && pnpm run pub-docs-git",
    "pub-docs-git": "wpm git-publish --source ./dist/docgeni-site --name docgeni-site --organization docgeni",
    "pub-lib": "ts-node --project ./scripts/tsconfig.json ./scripts/pub-lib.ts",
    "pub-lib-next": "ts-node --project ./scripts/tsconfig.json ./scripts/pub-lib.ts --tag next",
    "//pub-template": "cd dist/template && npm publish --access=public",
    "//pub-template-next": "cd dist/template && npm publish --access=public --tag=next",
    "build-styles": "cpx \"./packages/template/src/**/*.scss\" ./dist/template && sass ./packages/template/src/styles/index.scss >> dist/template/styles/index.css",
    "pretty": "pretty-quick --staged",
    "prettier": "prettier . --write",
    "install-examples": "cd examples/full && npm i && cd ../lite && npm i && cd ../../",
    "prepare": "husky"
  },
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=18.19.1",
    "pnpm": ">=9.0.0",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm"
  },
  "workspaces": [
    "./packages/cli",
    "./packages/core",
    "./packages/toolkit",
    "./packages/template",
    "./packages/ngdoc",
    "./packages/create-docgeni"
  ],
  "dependencies": {
    "@angular/animations": "^21.0.6",
    "@angular/common": "^21.0.6",
    "@angular/compiler": "^21.0.6",
    "@angular/core": "^21.0.6",
    "@angular/forms": "^21.0.6",
    "@angular/platform-browser": "^21.0.6",
    "@angular/platform-browser-dynamic": "^21.0.6",
    "@angular/router": "^21.0.6",
    "chokidar": "^3.6.0",
    "cosmiconfig": "^9.0.0",
    "docsearch.js": "2.6.3",
    "fancy-log": "^2.0.0",
    "marked": "18.0.4",
    "marked-emoji": "^2.0.3",
    "rxjs": "^7.8.2",
    "tslib": "^2.6.3",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.4",
    "@angular/cli": "^21.0.4",
    "@angular/compiler-cli": "^21.0.6",
    "@angular/language-service": "^21.0.6",
    "@commitlint/cli": "^19.4.0",
    "@commitlint/config-angular": "^19.3.0",
    "@eslint/compat": "^1.1.1",
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@ngneat/spectator": "^19.1.2",
    "@types/chai": "^4.2.11",
    "@types/jasmine": "~5.1.4",
    "@types/jasminewd2": "~2.0.13",
    "@types/node": "^24.10.0",
    "@types/watchpack": "^2.4.4",
    "@types/yargs": "^17.0.33",
    "@types/yargs-parser": "^21.0.3",
    "@typescript-eslint/eslint-plugin": "8.1.0",
    "@typescript-eslint/experimental-utils": "5.62.0",
    "@typescript-eslint/parser": "8.1.0",
    "@worktile/pkg-manager": "^0.2.0-next.4",
    "prismjs": "^1.29.0",
    "chai": "^4.2.0",
    "coveralls": "^3.1.1",
    "cpx": "^1.5.0",
    "cross-env": "^7.0.3",
    "eslint": "9.9.0",
    "eslint-formatter-autolinkable-stylish": "1.4.0",
    "eslint-plugin-import": "2.29.1",
    "eslint-plugin-no-null": "^1.0.2",
    "globals": "^17.6.0",
    "husky": "^9.1.4",
    "jasmine": "~5.2.0",
    "jasmine-core": "~5.2.0",
    "jasmine-spec-reporter": "^7.0.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "mocha": "^10.7.3",
    "ncp": "^2.0.0",
    "ng-packagr": "^21.0.1",
    "nyc": "^17.0.0",
    "prettier": "^3.3.3",
    "pretty-quick": "^4.0.0",
    "rimraf": "^6.0.1",
    "sass": "^1.100.0",
    "temp": "^0.9.4",
    "ts-node": "10.9.2",
    "typemoq": "^2.1.0",
    "typescript": "5.9.3",
    "write-json-file": "^7.0.0",
    "yargs-parser": "^22.0.0"
  },
  "keywords": [
    "angular",
    "docgeni",
    "docgen",
    "documentation",
    "docs",
    "markdown",
    "components",
    "library",
    "docs generator",
    "docs generate",
    "docs generator",
    "documentation generator",
    "static site generator"
  ],
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
      "pre-commit": "pretty-quick --staged"
    }
  }
}
